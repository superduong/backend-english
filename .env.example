DATABASE_URL=sqlite:///./dev.db
MOCK_PAYMENTS=true
SECRET_KEY=doi-thay-o-production
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Production: thêm https://ten-project.vercel.app — không có / cuối.
# Hoặc (tiện cho mọi preview Vercel):
# CORS_ORIGIN_REGEX=^https://.*\.vercel\.app$

# --- Thanh toán: URL công khai (Render) + frontend (Vercel), không dấu / cuối ---
# PUBLIC_API_URL=https://api-xxx.onrender.com
# FRONTEND_PUBLIC_URL=https://ten-app.vercel.app
# (VNPay vnp_ReturnUrl = FRONTEND_PUBLIC_URL + /payment/callback)

# VNPay (sandbox: VNPAY_PAYMENT_URL mặc định; prod: https://pay.vnpayment.vn/...)
# VNPAY_TMN_CODE=
# VNPAY_HASH_SECRET=

# MoMo test: https://test-payment.momo.vn/v2/gateway/api/create
# MOMO_PARTNER_CODE=
# MOMO_ACCESS_KEY=
# MOMO_SECRET_KEY=

# ZaloPay sandbox create
# ZALOPAY_APP_ID=
# ZALOPAY_KEY1=
# ZALOPAY_KEY2=

# VietQR — mã ngân hàng Napas 6 số + STK (ảnh QR qua img.vietqr.io)
# VIETQR_BANK_ID=970436
# VIETQR_ACCOUNT_NO=
# VIETQR_ACCOUNT_NAME=

# Xác nhận chuyển khoản thủ công sau đối soát — curl -H "X-Merchant-Key: ..." POST .../ops/confirm-bank-transfer/{payment_id}
# MERCHANT_MANUAL_API_KEY=
